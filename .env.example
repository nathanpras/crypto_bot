# ============================================================
# APEX Trading System — Environment Variables
# Copy this file to .env and fill in your actual values.
# ============================================================

# ── Exchange ──────────────────────────────────────────────────
BYBIT_API_KEY=your_bybit_api_key
BYBIT_API_SECRET=your_bybit_api_secret

# ── Telegram ──────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_telegram_chat_id

# ── Portfolio ─────────────────────────────────────────────────
PORTFOLIO_USD=1000
IDR_RATE=17800

# ── FRED / Macro ──────────────────────────────────────────────
FRED_API_KEY=your_fred_api_key

# ── Phase 8: Optional API keys for enhanced signals ──────────
# CoinGlass liquidation cascade data
COINGLASS_API_KEY=your_key_here

# LunarCrush social metrics
LUNARCRUSH_API_KEY=your_key_here

# Etherscan ETH on-chain data
ETHERSCAN_API_KEY=your_key_here

# Reddit sentiment analysis
REDDIT_CLIENT_ID=your_client_id
REDDIT_CLIENT_SECRET=your_client_secret
REDDIT_USER_AGENT=APEX/1.0

# Coinalyze historical funding rates
COINALYZE_API_KEY=your_key_here
